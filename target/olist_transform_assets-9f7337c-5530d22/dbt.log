{"data": {"conn_name": "model.olist_transform.stg_orders", "node_info": {"materialized": "view", "meta": {}, "node_checksum": "22947c35098f37b35f0c2fee60064ea327c1223ec121b220d6925ff333fa40f6", "node_finished_at": "", "node_name": "stg_orders", "node_path": "staging\\stg_orders.sql", "node_relation": {"alias": "stg_orders", "database": "OLIST_PROJECT", "relation_name": "OLIST_PROJECT.PUBLIC.stg_orders", "schema": "PUBLIC"}, "node_started_at": "2026-06-02T07:19:15.391939", "node_status": "executing", "resource_type": "model", "unique_id": "model.olist_transform.stg_orders"}, "sql": "create or replace   view OLIST_PROJECT.PUBLIC.stg_orders\n  \n  \n  \n  \n  as (\n    select \n    order_id,\n    customer_id,\n    order_status,\n    to_timestamp_ntz(order_purchase_timestamp/1000000000) as purchase_date,\n    to_timestamp_ntz(order_approved_at/1000000000) as approval_date,\n    to_timestamp_ntz(order_delivered_carrier_date/1000000000) as carrier_delivered_date,\n    to_timestamp_ntz(order_estimated_delivery_date/1000000000) as estimated_delivery_date,\n    to_timestamp_ntz(order_delivered_customer_date/1000000000) as customer_delivered_date,\nfrom OLIST_PROJECT.PUBLIC.RAW_ORDERS\n  )\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"olist_transform\", \"target_name\": \"dev\", \"node_id\": \"model.olist_transform.stg_orders\"} */;"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "8e114ccb-feaa-40ec-94bc-11738802d7d6", "level": "debug", "msg": "On model.olist_transform.stg_orders: create or replace   view OLIST_PROJECT.PUBLIC.stg_orders\n  \n  \n  \n  \n  as (\n    select \n    order_id,\n    customer_id,\n    order_status,\n    to_timestamp_ntz(order_purchase_timestamp/1000000000) as purchase_date,\n    to_timestamp_ntz(order_approved_at/1000000000) as approval_date,\n    to_timestamp_ntz(order_delivered_carrier_date/1000000000) as carrier_delivered_date,\n    to_timestamp_ntz(order_estimated_delivery_date/1000000000) as estimated_delivery_date,\n    to_timestamp_ntz(order_delivered_customer_date/1000000000) as customer_delivered_date,\nfrom OLIST_PROJECT.PUBLIC.RAW_ORDERS\n  )\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.11\", \"profile_name\": \"olist_transform\", \"target_name\": \"dev\", \"node_id\": \"model.olist_transform.stg_orders\"} */;", "name": "SQLQuery", "pid": 20048, "thread": "Thread-3 (worker)", "ts": "2026-06-02T07:19:15.814962Z"}}
